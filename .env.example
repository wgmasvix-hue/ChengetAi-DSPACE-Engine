# =============================================================================
# ChengetAi DSpace Engine — deployment configuration
#
# Copy this file to `.env` and adjust per deployment. The `.env` file is
# gitignored: it is the ONLY place deployment-specific values should live.
#
# This file is read by both docker compose and the shell scripts in scripts/,
# so ALWAYS double-quote values that contain spaces or special characters.
# =============================================================================

# --- Deployment identity -----------------------------------------------------

# Short name for this deployment (used in container names and backup files)
COMPOSE_PROJECT_NAME=chengetai-dspace

# development | production
DEPLOY_ENV=development

# Public hostname of this deployment (used by the nginx overlay and TLS)
DSPACE_HOSTNAME=dspace.example.org

# --- DSpace version ----------------------------------------------------------

# Image tag shared by all DSpace images (backend, frontend, db, solr).
# Use a release branch tag (e.g. dspace-9_x) or a pinned release (e.g. dspace-9.1).
DSPACE_VER=dspace-9_x

# --- Public URLs -------------------------------------------------------------

# Development defaults (localhost). For production behind the nginx overlay:
#   DSPACE_UI_URL=https://${DSPACE_HOSTNAME}
#   DSPACE_REST_URL=https://${DSPACE_HOSTNAME}/server
DSPACE_UI_URL=http://localhost:4000
DSPACE_REST_URL=http://localhost:8080/server

# Site name shown in the UI (keep the quotes — the value contains spaces)
DSPACE_NAME="ChengetAi Digital Repository"

# --- Frontend (Angular UI) ---------------------------------------------------

DSPACE_UI_PORT=4000

# How the UI's server-side rendering reaches the REST API. Inside the compose
# network the backend is reachable as `dspace` on port 8080.
DSPACE_REST_SSL=false
DSPACE_REST_HOST=dspace
DSPACE_REST_PORT=8080
DSPACE_REST_NAMESPACE=/server

# --- Backend -----------------------------------------------------------------

DSPACE_BACKEND_PORT=8080

# --- Database ----------------------------------------------------------------

POSTGRES_DB=dspace
POSTGRES_USER=dspace
# REQUIRED: set a strong password before first start. Changing it after the
# database volume exists requires updating the password inside PostgreSQL too.
POSTGRES_PASSWORD=

# --- Solr --------------------------------------------------------------------

# Solr is bound to 127.0.0.1 only; never expose it publicly.
SOLR_PORT=8983

# --- Mail (production) ---------------------------------------------------------

# Leave blank in development (DSpace will log mail instead of sending).
MAIL_SERVER=
MAIL_SERVER_PORT=25
MAIL_SERVER_USERNAME=
MAIL_SERVER_PASSWORD=
MAIL_FROM_ADDRESS=noreply@example.org
MAIL_ADMIN_ADDRESS=admin@example.org

# --- Initial administrator (used by scripts/init-admin.sh) --------------------

ADMIN_EMAIL=admin@example.org
ADMIN_FIRSTNAME="Repository"
ADMIN_LASTNAME="Administrator"
# Leave blank to be prompted interactively (recommended)
ADMIN_PASSWORD=
